# FinanceTrack Configuration Example
# Copy this file to .env and fill in your actual values

# ===== DATABASE =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here_change_me
POSTGRES_DB=financetrack
DATABASE_URL=postgresql://postgres:your_secure_password_here_change_me@postgres:5432/financetrack

# ===== BACKEND SERVER =====
NODE_ENV=development
PORT=3000
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_me

# ===== FRONTEND =====
VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_NAME=FinanceTrack

# ===== CORS =====
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ===== SSL/TLS (Produção) =====
# Caminho para certificados SSL (opcional, deixar em branco para usar HTTP)
SSL_CERT=/etc/ssl/certs/cert.pem
SSL_KEY=/etc/ssl/private/key.pem

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== RATE LIMITING =====
# Limites por janela de tempo
AUTH_RATE_LIMIT_WINDOW=15
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=100
TRANSACTION_RATE_LIMIT_MAX=30

# ===== FEATURES =====
ENABLE_USER_REGISTRATION=true
ENABLE_PASSWORD_RESET=true

# ===== EMAIL CONFIGURATION =====
# Gmail configuration (requires app-specific password)
EMAIL_SERVICE=gmail
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app
EMAIL_FROM=noreply@financetrack.com
FRONTEND_URL=https://seu-dominio.com

# ===== SECURITY =====
BCRYPT_ROUNDS=12
